# ─── SERVER ──────────────────────────────────────────────────────────────────
PORT=3004
NODE_ENV=development

# ─── POSTGRES ─────────────────────────────────────────────────────────────────
# Docker: POSTGRES_HOST=postgres_bloodstock | Local: POSTGRES_HOST=localhost
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=bloodstock

# ─── AUTH ─────────────────────────────────────────────────────────────────────
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Deve ser IGUAL ao JWT_SECRET de todos os outros serviços
JWT_SECRET=

# ─── INTEGRAÇÃO INTERNA ───────────────────────────────────────────────────────
# Segredo compartilhado com users-service para o webhook /api/stock/init
# DEV: internal-dev-secret | PROD: gerar com openssl rand -hex 32
INTERNAL_SECRET=

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000


# ─── OBSERVABILIDADE ─────────────────────────────────────────────────────────
BETTERSTACK_SOURCE_TOKEN=
LOG_LEVEL=info
