# Sangue Solidário — .env template
# Copiar para .env e preencher. Gerar secrets: openssl rand -base64 48

# ─── Databases ───────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=change-me

# ─── JWT / cookies ───────────────────────────────────────────────
# MESMO valor em TODOS os serviços (token gerado no users-service e validado local nos outros)
JWT_SECRET=change-me-openssl-rand-base64-48
COOKIE_SECRET=change-me-openssl-rand-base64-48
INTERNAL_SECRET=change-me-openssl-rand-base64-48

# ─── Cloudinary ──────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Mapbox ──────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxx
MAPBOX_ACCESS_TOKEN=pk.xxx

# ─── Google OAuth ────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ─── Gemini API ──────────────────────────────────────────────────
GEMINI_API_KEY=
